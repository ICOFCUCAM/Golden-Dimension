# =============================================================================
# Frontend (Vite — exposed in the browser bundle)
# =============================================================================
# Get these from https://supabase.com/dashboard
#   → your project → Settings → Data API
#   - Project URL              -> VITE_SUPABASE_URL
#   - Project API Keys → anon  -> VITE_SUPABASE_ANON_KEY
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# =============================================================================
# Backend (Vercel serverless functions in /api — never sent to the browser)
# =============================================================================
# Used by /api/create-checkout-session and /api/stripe-webhook to verify
# invoices server-side and write payments back. Use the SAME Supabase project
# as above; the service-role key bypasses RLS so only the server has it.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe — only needed if you enable Card payments in payment_methods_config.
#   STRIPE_SECRET_KEY: from https://dashboard.stripe.com/apikeys
#   STRIPE_WEBHOOK_SECRET: from the webhook endpoint you create at
#     https://dashboard.stripe.com/webhooks → Add endpoint
#     URL: https://<your-domain>/api/stripe-webhook
#     Event: checkout.session.completed
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
